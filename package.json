{
  "name": "@orqastudio/svelte-components",
  "version": "0.1.0",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-package -i src -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./pure": {
      "types": "./dist/pure/index.d.ts",
      "svelte": "./dist/pure/index.js",
      "default": "./dist/pure/index.js"
    },
    "./connected": {
      "types": "./dist/connected/index.d.ts",
      "svelte": "./dist/connected/index.js",
      "default": "./dist/connected/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./tokens": "./dist/tokens/index.css"
  },
  "files": [
    "dist",
    "!dist/**/*.stories.*"
  ],
  "peerDependencies": {
    "@orqastudio/sdk": ">=0.1.0",
    "@orqastudio/types": ">=0.1.0",
    "svelte": ">=5.0.0"
  },
  "dependencies": {
    "@lucide/svelte": "^0.561.0",
    "bits-ui": "^2.16.2",
    "clsx": "^2.1.1",
    "paneforge": "^1.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-svelte-csf": "^5.0.0-next.9",
    "@storybook/svelte": "^8.6.14",
    "@storybook/svelte-vite": "^8.6.14",
    "@storybook/sveltekit": "^8.6.14",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "storybook": "^8.6.14",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  }
}
